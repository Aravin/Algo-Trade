# ─── Upstox OAuth ───────────────────────────────────────────────
# Obtained from https://account.upstox.com/developer/apps
# Used only during the server-side token exchange (worker/index.ts).
# Never expose these in the browser bundle.
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# The redirect URI registered in your Upstox developer app.
# For local dev: http://localhost:5173/broker/callback
# For production: https://<your-domain>/broker/callback
UPSTOX_REDIRECT_URI=http://localhost:5173/broker/callback

# ─── Auth0 Client Configurations ────────────────────────────────
VITE_AUTH0_DOMAIN=algo-trade.us.auth0.com
VITE_AUTH0_CLIENT_ID=8wwVnXMFevBSIyaJvHJnDU9hWkm6iuhq
VITE_AUTH0_AUDIENCE=https://api.algo-trade.com
